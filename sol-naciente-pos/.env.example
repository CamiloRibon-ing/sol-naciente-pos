# === Supabase ===
# Si dejas estas variables vacías, la app arranca en MODO DEMO con datos de ejemplo.
# Cuando las completes, la app se conecta automáticamente a tu base de datos.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# === Cloudinary (subida de imágenes de productos) ===
# Crea un "Upload preset" UNSIGNED en tu panel de Cloudinary:
# Settings > Upload > Upload presets > Add > Signing Mode: Unsigned
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
